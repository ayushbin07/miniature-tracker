generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HabitType {
  PRODUCTIVITY
  HEALTH
  FITNESS
  EDUCATION
  FINANCE
  RELATIONSHIP
  PERSONAL
  SPIRITUAL
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

enum AvatarType {
  GENERATED
  CUSTOM
}

model User {
  id          String        @id @default(cuid())

  name        String
  username    String        @unique
  email       String        @unique

  avatarType  AvatarType    @default(GENERATED)
  avatarSeed  String
  avatarUrl   String?

  habits      Habit[]
  tasks       Task[]
  notes       Note[]
  categories  Category[]
  settings    UserSettings?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Category {
  id          String      @id @default(cuid())

  userId      String

  name        String
  color       String
  icon        String?

  habits      Habit[]
  tasks       Task[]
  notes       Note[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
}

model Habit {
  id          String       @id @default(cuid())

  userId      String
  categoryId  String?

  title       String
  description String?

  type        HabitType
  frequency   Frequency

  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  user         User        @relation(fields: [userId], references: [id])
  category     Category?   @relation(fields: [categoryId], references: [id])

  habitLogs    HabitLog[]
}

model HabitLog {
  id          String      @id @default(cuid())

  habitId     String

  completedAt DateTime

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  habit       Habit       @relation(fields: [habitId], references: [id])
}

model Task {
  id          String       @id @default(cuid())

  userId      String
  categoryId  String?

  title       String
  description String?

  priority    Priority     @default(MEDIUM)
  status      TaskStatus   @default(TODO)

  dueDate     DateTime?
  completedAt DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User        @relation(fields: [userId], references: [id])
  category     Category?   @relation(fields: [categoryId], references: [id])
}

model Note {
  id          String      @id @default(cuid())

  userId      String
  categoryId  String?

  title       String
  content     String

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  user         User       @relation(fields: [userId], references: [id])
  category     Category?  @relation(fields: [categoryId], references: [id])
}

model UserSettings {
  id            String      @id @default(cuid())

  userId         String      @unique

  theme          Theme       @default(SYSTEM)
  timezone       String      @default("Asia/Kathmandu")
  language       String      @default("en")
  weekStartsOn   Int         @default(1)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id])
}